GLM_API_KEY=                         # 必填，智谱 GLM API Key
GLM_MODEL=glm-4.7                    # BrandFlow Agent API 默认模型
AGENT_DATABASE_URL=                  # PostgreSQL 连接，仅 Agent API 服务端使用
AGENT_CHECKPOINT_DATABASE_URL=       # 独立 checkpoint 角色/Schema 连接
BRAND_MCP_URL=http://127.0.0.1:8100/mcp  # Agent API 使用的真实 MCP transport
BRAND_MCP_SERVICE_TOKEN=             # Agent API → MCP 内部服务凭证
BRAND_MCP_DATABASE_URL=              # MCP 独立数据库角色连接
BRANDFLOW_AGENT_INTERNAL_URL=http://127.0.0.1:8000 # Next.js same-origin proxy → Agent API
POSTGRES_ADMIN_PASSWORD=             # docker compose 本地 PostgreSQL 管理密码
AGENT_DB_PASSWORD=                   # docker compose 业务角色密码
CHECKPOINT_DB_PASSWORD=              # docker compose checkpoint 独立角色密码
NEXT_PUBLIC_SUPABASE_URL=            # Supabase 项目 URL（可选）
NEXT_PUBLIC_SUPABASE_ANON_KEY=       # Supabase 匿名密钥（可选）
SUPABASE_SERVICE_ROLE_KEY=           # Supabase 服务密钥（可选）
